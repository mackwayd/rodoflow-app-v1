# Copie este arquivo para keystore.properties (na raiz rodoflow-app/).
# keystore.properties NÃO deve ir para o Git — já está no .gitignore.
#
# 1) Gere o keystore (uma vez), na pasta release/:
#    keytool -genkeypair -v -storetype PKCS12 -keyalg RSA -keysize 2048 -validity 10000 ^
#      -alias rodoflow -keystore release/rodoflow-release.jks ^
#      -storepass SUA_SENHA -keypass SUA_SENHA ^
#      -dname "CN=RodoFlow, OU=Mobile, O=RodoFlow, L=Cidade, ST=UF, C=BR"
#
# 2) Preencha os valores abaixo (storeFile relativo à raiz do projeto rodoflow-app):

storeFile=release/rodoflow-release.jks
storePassword=SUA_SENHA_DA_KEYSTORE
keyAlias=rodoflow
keyPassword=SUA_SENHA_DA_CHAVE
